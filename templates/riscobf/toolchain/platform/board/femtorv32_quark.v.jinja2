`timescale 1ns / 1ps

/*******************************************************************/
// Bruno Levy, Matthias Koch, 2020-2021
/*******************************************************************/

module FemtoRV32 (
    input clk,

    output [31:0] mem_addr,
    output [31:0] mem_wdata,
    output [3:0] mem_wmask,
    input [31:0] mem_rdata,
    output mem_rstrb,
    input mem_rbusy,
    input mem_wbusy,

    input reset
);

  parameter RESET_ADDR = 32'h00000000;
  parameter STACK_INIT = 32'h00020000;

  /***************************************************************************/
  // Instruction decoding.
  /***************************************************************************/

  // Extracts rd,rs1,rs2,funct3,imm and opcode from instruction.
  // Reference: Table page 104 of:
  // https://content.riscv.org/wp-content/uploads/2017/05/riscv-spec-v2.2.pdf

  // The destination register
  wire [ 4:0] rdId = instr[11:7];

  // The five immediate formats, see RiscV reference (link above), Fig. 2.4 p. 12
  wire [31:0] Uimm = {instr[31], instr[30:12], {12{1'b0}}};
  wire [31:0] Iimm = {{21{instr[31]}}, instr[30:20]};
  /* verilator lint_off UNUSED */  // MSBs of SBJimms are not used by addr adder.
  wire [31:0] Simm = {{21{instr[31]}}, instr[30:25], instr[11:7]};
  wire [31:0] Bimm = {{20{instr[31]}}, instr[7], instr[30:25], instr[11:8], 1'b0};
  wire [31:0] Jimm = {{12{instr[31]}}, instr[19:12], instr[20], instr[30:21], 1'b0};
  /* verilator lint_on UNUSED */

  wire        isLoad     = (instr[6:0] == 7'b[[[ opcode_load ]]]);    // rd <- mem[rs1+Iimm]
  wire        isALUimm   = (instr[6:0] == 7'b[[[ opcode_opimm ]]]);   // rd <- rs1 OP Iimm
  wire        isStore    = (instr[6:0] == 7'b[[[ opcode_store ]]]);   // mem[rs1+Simm] <- rs2
  wire        isALUreg   = (instr[6:0] == 7'b[[[ opcode_alur ]]]);    // rd <- rs1 OP rs2
  wire        isJAL      = (instr[6:0] == 7'b[[[ opcode_jal ]]]);     // rd <- PC+4; PC<-PC+Jimm
  wire        isJALR     = (instr[6:0] == 7'b[[[ opcode_jalr ]]]);    // rd <- PC+4; PC<-rs1+Iimm
  wire        isLUI      = (instr[6:0] == 7'b[[[ opcode_lui ]]]);     // rd <- Uimm
  wire        isAUIPC    = (instr[6:0] == 7'b[[[ opcode_auipc ]]]);   // rd <- PC + Uimm
  wire        isBranch   = (instr[6:0] == 7'b[[[ opcode_branch ]]]);  // if(rs1 OP rs2) PC<-PC+Bimm

  wire        isALU = isALUimm | isALUreg;
  wire        isLoadStore = isLoad | isStore;

  //ALU Operation Decoding...
  wire        aluop_is_addsub = isALU & (instr[14:12] == 3'b[[[ funct3_add_sub ]]]);
  wire        aluop_is_sll    = isALU & (instr[14:12] == 3'b[[[ funct3_sll ]]]);
  wire        aluop_is_slt    = isALU & (instr[14:12] == 3'b[[[ funct3_slt ]]]);
  wire        aluop_is_sltu   = isALU & (instr[14:12] == 3'b[[[ funct3_sltu ]]]);
  wire        aluop_is_xor    = isALU & (instr[14:12] == 3'b[[[ funct3_xor ]]]);
  wire        aluop_is_srx    = isALU & (instr[14:12] == 3'b[[[ funct3_srx ]]]);
  wire        aluop_is_or     = isALU & (instr[14:12] == 3'b[[[ funct3_or ]]]);
  wire        aluop_is_and    = isALU & (instr[14:12] == 3'b[[[ funct3_and ]]]);

  //Branch Decoding
  wire        brop_beq   = isBranch & (instr[14:12] == 3'b[[[ funct3_beq ]]]);
  wire        brop_bne   = isBranch & (instr[14:12] == 3'b[[[ funct3_bne ]]]);
  wire        brop_blt   = isBranch & (instr[14:12] == 3'b[[[ funct3_blt ]]]);
  wire        brop_bge   = isBranch & (instr[14:12] == 3'b[[[ funct3_bge ]]]);
  wire        brop_bltu  = isBranch & (instr[14:12] == 3'b[[[ funct3_bltu ]]]);
  wire        brop_bgeu  = isBranch & (instr[14:12] == 3'b[[[ funct3_bgeu ]]]);

  wire loadstore_is_byte =
    isLoadStore &
    ((instr[14:12] == 3'b[[[ funct3_lb ]]])  | (instr[14:12] == 3'b[[[ funct3_lbu ]]]) |
     (instr[14:12] == 3'b[[[ funct3_sb ]]]));

  wire loadstore_is_half =
    isLoadStore &
    ((instr[14:12] == 3'b[[[ funct3_lh ]]])  | (instr[14:12] == 3'b[[[ funct3_lhu ]]]) |
     (instr[14:12] == 3'b[[[ funct3_sh ]]]));

  wire loadstore_is_word =
    isLoadStore &
    ((instr[14:12] == 3'b[[[ funct3_lw ]]])  | (instr[14:12] == 3'b[[[ funct3_sw ]]]));

  wire is_load_unsigned =
    isLoad &
    ((instr[14:12] == 3'b[[[ funct3_lbu ]]]) | (instr[14:12] == 3'b[[[ funct3_lhu ]]]));

  wire [6:0]  funct7 = instr[31:25];

  wire is_sub_not_add = isALUreg & aluop_is_addsub & (funct7 == 7'b[[[ funct7_sub ]]]); 
  wire is_sra_not_srl = isALU & aluop_is_srx & (funct7 == 7'b[[[funct7_sra]]]);

  /***************************************************************************/
  // The register file.
  /***************************************************************************/

  reg  [31:0] rs1;
  reg  [31:0] rs2;

  (* no_rw_check *)
  reg  [31:0] registerFile                                                          [31:0];

  always @(posedge clk) begin
    if (writeBack) if (rdId != 0) registerFile[rdId] <= writeBackData;
  end

  /***************************************************************************/
  // The ALU. Does operations and tests combinatorially, except shifts.
  /***************************************************************************/

  // First ALU source, always rs1
  wire [31:0] aluIn1 = rs1;

  // Second ALU source, depends on opcode:
  //    ALUreg, Branch:     rs2
  //    ALUimm, Load, JALR: Iimm
  wire [31:0] aluIn2 = isALUreg | isBranch ? rs2 : Iimm;

  reg [31:0] aluReg;  // The internal register of the ALU, used by shift.
  reg [4:0] aluShamt;  // Current shift amount.

  wire aluBusy = |aluShamt;  // ALU is busy if shift amount is non-zero.
  wire aluWr;  // ALU write strobe, starts shifting.

  // The adder is used by both arithmetic instructions and JALR.
  wire [31:0] aluPlus = aluIn1 + aluIn2;

  
  [[[ render_section("alu_combinatorial") ]]]

  wire [31:0] addsub_out = is_sub_not_add ? aluMinus[31:0] : aluPlus;

  wire [31:0] aluOut =
     (aluop_is_addsub  ? addsub_out                                       : 32'b0) |
     (aluop_is_slt  ? {31'b0, LT}                                         : 32'b0) |
     (aluop_is_sltu  ? {31'b0, LTU}                                        : 32'b0) |
     (aluop_is_xor  ? aluIn1 ^ aluIn2                                     : 32'b0) |
     (aluop_is_or  ? aluIn1 | aluIn2                                     : 32'b0) |
     (aluop_is_and  ? aluIn1 & aluIn2                                     : 32'b0) |
     (funct3IsShift ? aluReg                                             : 32'b0) ;

  wire funct3IsShift = isALU & (aluop_is_sll | aluop_is_srx);

  always @(posedge clk) begin
    if (aluWr) begin
      if (funct3IsShift) begin  // SLL, SRA, SRL
        aluReg   <= aluIn1;
        aluShamt <= aluIn2[4:0];
      end
    end

    // Compact form of:
    // funct3=001              -> SLL  (aluReg <= aluReg << 1)
    // funct3=101 &  instr[30] -> SRA  (aluReg <= {aluReg[31], aluReg[31:1]})
    // funct3=101 & !instr[30] -> SRL  (aluReg <= {1'b0,       aluReg[31:1]})

    if (|aluShamt) begin
      aluShamt <= aluShamt - 1;
      aluReg <= aluop_is_sll ? aluReg << 1 :  // SLL
      {is_sra_not_srl & aluReg[31], aluReg[31:1]};  // SRA,SRL
    end
  end

  /***************************************************************************/
  // The predicate for conditional branches.
  /***************************************************************************/

  wire predicate = brop_beq & EQ |  // BEQ
  brop_bne & !EQ |  // BNE
  brop_blt & LT |  // BLT
  brop_bge & !LT |  // BGE
  brop_bltu & LTU |  // BLTU
  brop_bgeu & !LTU;  // BGEU

  /***************************************************************************/
  // Program counter and branch target computation.
  /***************************************************************************/

  reg [31:0] PC;  // The program counter.
  reg [31:0] instr;  // Latched instruction. Note that bits 0 and 1 are
                     // ignored (not used in RV32I base instr set).

  wire [31:0] PCplus4 = PC + 4;

  // An adder used to compute branch address, JAL address and AUIPC.
  // branch->PC+Bimm    AUIPC->PC+Uimm    JAL->PC+Jimm
  // Equivalent to PCplusImm = PC + (isJAL ? Jimm : isAUIPC ? Uimm : Bimm)
  wire [31:0] PCplusImm =
    PC + (isJAL   ? Jimm[31:0] :
          isAUIPC ? Uimm[31:0] :
                    Bimm[31:0]);

  // A separate adder to compute the destination of load/store.
  // testing instr[5] is equivalent to testing isStore in this context.
  wire [31:0] loadstore_addr = rs1[31:0] +
      (isStore ? Simm[31:0] : Iimm[31:0]);

  /* verilator lint_off WIDTH */
  // internal address registers and cycles counter may have less than 
  // 32 bits, so we deactivate width test for mem_addr and writeBackData

  assign mem_addr = state[WAIT_INSTR_bit] | state[FETCH_INSTR_bit] ? PC : loadstore_addr;

  /***************************************************************************/
  // The value written back to the register file.
  /***************************************************************************/

  wire [31:0] writeBackData = (isLUI ? Uimm : 32'b0) |  // LUI
  (isALU ? aluOut : 32'b0) |  // ALUreg, ALUimm
  (isAUIPC ? PCplusImm : 32'b0) |  // AUIPC
  (isJALR | isJAL ? PCplus4 : 32'b0) |  // JAL, JALR
  (isLoad ? LOAD_data : 32'b0);  // Load

  /* verilator lint_on WIDTH */


  /***************************************************************************/
  // LOAD/STORE
  /***************************************************************************/

  wire LOAD_sign =
    isLoad &
    !is_load_unsigned &
    ( loadstore_is_byte ? LOAD_byte[7] :
      loadstore_is_half ? LOAD_halfword[15] :
      1'b0 );

  wire [31:0] LOAD_data =
         loadstore_is_byte ? {{24{LOAD_sign}},     LOAD_byte} :
     loadstore_is_half ? {{16{LOAD_sign}}, LOAD_halfword} :
                          mem_rdata ;

  wire [15:0] LOAD_halfword = loadstore_addr[1] ? mem_rdata[31:16] : mem_rdata[15:0];

  wire [7:0] LOAD_byte = loadstore_addr[0] ? LOAD_halfword[15:8] : LOAD_halfword[7:0];

  // STORE

  assign mem_wdata[7:0] = rs2[7:0];
  assign mem_wdata[15:8] = loadstore_addr[0] ? rs2[7:0] : rs2[15:8];
  assign mem_wdata[23:16] = loadstore_addr[1] ? rs2[7:0] : rs2[23:16];
  assign mem_wdata[31:24] = loadstore_addr[0] ? rs2[7:0]  :
			     loadstore_addr[1] ? rs2[15:8] : rs2[31:24];

  // The memory write mask:
  //    1111                     if writing a word
  //    0011 or 1100             if writing a halfword
  //                                (depending on loadstore_addr[1])
  //    0001, 0010, 0100 or 1000 if writing a byte
  //                                (depending on loadstore_addr[1:0])

  wire [3:0] STORE_wmask =
	      loadstore_is_byte      ?
	            (loadstore_addr[1] ?
		          (loadstore_addr[0] ? 4'b1000 : 4'b0100) :
		          (loadstore_addr[0] ? 4'b0010 : 4'b0001)
                    ) :
	      loadstore_is_half ?
	            (loadstore_addr[1] ? 4'b1100 : 4'b0011) :
              4'b1111;

  /*************************************************************************/
  // And, last but not least, the state machine.
  /*************************************************************************/

  localparam FETCH_INSTR_bit = 0;
  localparam WAIT_INSTR_bit = 1;
  localparam EXECUTE_bit = 2;
  localparam WAIT_ALU_OR_MEM_bit = 3;
  localparam NB_STATES = 4;

  localparam FETCH_INSTR = 1 << FETCH_INSTR_bit;
  localparam WAIT_INSTR = 1 << WAIT_INSTR_bit;
  localparam EXECUTE = 1 << EXECUTE_bit;
  localparam WAIT_ALU_OR_MEM = 1 << WAIT_ALU_OR_MEM_bit;

  (* onehot *)
  reg [NB_STATES-1:0] state;

  // The signals (internal and external) that are determined
  // combinatorially from state and other signals.

  // register write-back enable.
  wire writeBack = ~(isBranch | isStore) & (state[EXECUTE_bit] | state[WAIT_ALU_OR_MEM_bit]);

  // The memory-read signal.
  assign mem_rstrb = state[EXECUTE_bit] & isLoad | state[FETCH_INSTR_bit];

  // The mask for memory-write.
  assign mem_wmask = {4{state[EXECUTE_bit] & isStore}} & STORE_wmask;

  // aluWr starts computation (shifts) in the ALU.
  assign aluWr = state[EXECUTE_bit] & isALU;

  wire jumpToPCplusImm = isJAL | (isBranch & predicate);
  wire needToWait = isLoad | isStore | isALU & funct3IsShift;

  [[[ render_section("decrypt_instruction") ]]]

  always @(posedge clk) begin
    if (!reset) begin
      state           <= WAIT_ALU_OR_MEM;  // Just waiting for !mem_wbusy
      PC              <= RESET_ADDR[31:0];
      registerFile[2] <= STACK_INIT;
    end else

      // See note [1] at the end of this file.
      (* parallel_case *)
      case (1'b1)

        state[WAIT_INSTR_bit]: begin
          if (!mem_rbusy) begin
            rs1   <= registerFile[instr_dec[19:15]];
            rs2   <= registerFile[instr_dec[24:20]];
            instr <= instr_dec;
            state <= EXECUTE;
          end
        end

        state[EXECUTE_bit]: begin
          PC    <= isJALR ? {aluPlus[31:1], 1'b0} : jumpToPCplusImm ? PCplusImm : PCplus4;
          state <= needToWait ? WAIT_ALU_OR_MEM : FETCH_INSTR;
        end

        state[WAIT_ALU_OR_MEM_bit]: begin
          if (!aluBusy & !mem_rbusy & !mem_wbusy) state <= FETCH_INSTR;
        end

        default: begin  // FETCH_INSTR
          state <= WAIT_INSTR;
        end

      endcase
  end
endmodule

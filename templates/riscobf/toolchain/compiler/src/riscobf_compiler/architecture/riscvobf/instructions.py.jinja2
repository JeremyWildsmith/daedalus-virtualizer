class RiscObfInstruction(Instruction):
    tokens = [RiscObfToken]
    isa = isa
 

class RiscObfInstructionNew(RiscObfInstruction):
    spec_key: str = None
    isa = isa
        
    @classmethod
    def spec(cls):
        return _load_spec(cls.spec_key)
    
    @classmethod
    def spec_pattern(cls):
        return cls.spec()[1]
    
    @classmethod
    def spec_token(cls):
        return cls.spec()[0];
    
    def get_tokens(self):
        tok = self.spec_token()
        return TokenSequence([tok()])
    
    @property
    def patterns(self):
        merged = dict(self.spec_pattern())

        if "operand_patterns" in type(self).__dict__:
            effective_operands = {
                key: (value(self) if callable(value) else value)
                for key, value in type(self).operand_patterns.items()
            }
            
            merged.update(effective_operands)

        return merged

class PseudoRiscObfInstruction(ArtificialInstruction):
    isa = isa
    pass


class Align(PseudoRiscObfInstruction):
    imm = Operand("imm", int)
    syntax = Syntax([".", "align", " ", imm])

    def render(self):
        self.rep = self.syntax.render(self)
        yield Alignment(self.imm, self.rep)


class Section(PseudoRiscObfInstruction):
    sec = Operand("sec", str)
    syntax = Syntax([".", "section", " ", sec])

    def render(self):
        self.rep = self.syntax.render(self)
        yield SectionInstruction(self.sec, self.rep)


def dcd(v):
    if type(v) is int:
        return Dd(v)
    elif type(v) is str:
        return Dcd2(v)
    else:  # pragma: no cover
        raise NotImplementedError()


class Dcd2(RiscObfInstruction):
    v = Operand("v", str)
    syntax = Syntax(["dcd", "=", v])

    def encode(self):
        tokens = self.get_tokens()
        tokens[0][0:32] = 0
        return tokens[0].encode()

    def relocations(self):
        return [AbsAddr32Relocation(self.v)]


def make_alu_r(spec, mnemonic):
    rd = Operand("rd", RiscObfRegister, write=True)
    rn = Operand("rn", RiscObfRegister, read=True)
    rm = Operand("rm", RiscObfRegister, read=True)
    syntax = Syntax([mnemonic, " ", rd, ",", " ", rn, ",", " ", rm])

    patterns = {
        "rs1": rn,
        "rs2": rm,
        "rd": rd
    }
    
    members = {
        "syntax": syntax,
        "rd": rd,
        "rn": rn,
        "rm": rm,
        "operand_patterns": patterns,
        "spec_key": spec
    }

    name = mnemonic.title() + "RegRegReg"
    return type(name, (RiscObfInstructionNew,), members)


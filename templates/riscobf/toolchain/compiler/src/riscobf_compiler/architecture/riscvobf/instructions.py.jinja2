@isa.pattern("stm", "CJMPI32(reg, reg)", size=6)
@isa.pattern("stm", "CJMPI16(reg, reg)", size=6)
@isa.pattern("stm", "CJMPI8(reg, reg)", size=6)
def pattern_cjmpi(context, tree, c0, c1):
    op, yes_label, no_label = tree.value

    # Inverted condition mapping (so we branch-to-skip when NOT cond)
    inv = {"<": Bge,  ">": Ble,  "==": Bne, "!=": Beq, ">=": Blt, "<=": Bgt}
    Bnot = inv[op]

    skip = context.new_label()

    # if NOT cond -> skip (skip is local and emitted immediately, so SB offset always fits)
    context.emit(Bnot(c0, c1, skip.name, jumps=[skip]))

    # cond true:
    context.emit(B(yes_label.name, jumps=[yes_label]))

    # skip:
    context.emit(skip)

    # cond false:
    context.emit(B(no_label.name, jumps=[no_label]))


@isa.pattern("stm", "CJMPU8(reg, reg)", size=6)
@isa.pattern("stm", "CJMPU16(reg, reg)", size=6)
@isa.pattern("stm", "CJMPU32(reg, reg)", size=6)
def pattern_cjmpu(context, tree, c0, c1):
    op, yes_label, no_label = tree.value

    inv = {"<": Bgeu, ">": Bleu, "==": Bne, "!=": Beq, ">=": Bltu, "<=": Bgtu}
    Bnot = inv[op]

    skip = context.new_label()

    context.emit(Bnot(c0, c1, skip.name, jumps=[skip]))
    context.emit(B(yes_label.name, jumps=[yes_label]))
    context.emit(skip)
    context.emit(B(no_label.name, jumps=[no_label]))



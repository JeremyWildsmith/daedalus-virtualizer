architecture_config_spec = None

def configure_isa_spec(config):
    global architecture_config_spec
    architecture_config_spec = dict(config)

def _create_spec_result(source, parent=None):
    token_map = {
        "RiscObfToken": RiscObfToken,
        "RiscObfIToken": RiscObfIToken,
        "RiscObfSToken": RiscObfSToken,
        "RiscObfSBToken": RiscObfSBToken,
        "RiscObfJToken": RiscObfJToken,
        "RiscObfUToken": RiscObfUToken
    }
    
    token = token_map.get(source.get("token"))
    
    if not token and parent:
        token = token_map.get(parent.get("token"))
    
    if not token:
        raise Exception("Could not find token for instruction spec.")
    
    r = {}
    for origin in [parent, source]:
        if not origin:
            continue

        for k, v in origin.items():
            if k in ("name", "token", "group", "derived"):
                continue
                
            r[k] = int(v, 2)
        
    return (token, r)    

def _load_spec(name: str) -> dict:
    if not architecture_config_spec:
        raise Exception("No specification loaded. Call configure_isa_spec before using ISA.")
    
    encoding = architecture_config_spec["encoding"]

    for i in encoding:
        if i.get("name") == name:
            return _create_spec_result(i)
            
    for i in encoding:
        derived = i.get("derived", [])
        
        for d in derived:
            if d.get("name") == name:
                return _create_spec_result(d, i)

    raise Exception(f"Instruction '{name}' has no configured encoding.")



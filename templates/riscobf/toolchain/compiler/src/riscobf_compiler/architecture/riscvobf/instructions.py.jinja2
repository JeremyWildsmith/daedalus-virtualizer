Bgtu = make_branch("bltu", "bgtu", True)
Bleu = make_branch("bgeu", "bleu", True)

Beq = make_branch("beq", "beq", False)
Bne = make_branch("bne", "bne", False)


def reg_list_to_mask(reg_list):
    mask = 0
    for reg in reg_list:
        mask |= 1 << reg.num
    return mask


def make_str(spec_key, mnemonic):
    rs2 = Operand("rs2", RiscObfRegister, read=True)
    offset = Operand("offset", int)
    rs1 = Operand("rs1", RiscObfRegister, read=True)
    syntax = Syntax([mnemonic, " ", rs2, ",", " ", offset, "(", rs1, ")"])
    
    operand_patterns = {
        "imm": lambda self: self.offset & 0xFFF,
        "rs1": rs1,
        "rs2": rs2,
    }
    
    members = {
        "syntax": syntax,
        "operand_patterns": operand_patterns,
        "spec_key": spec_key,
        "rs1": rs1,
        "rs2": rs2,
        "offset": offset
    }
    return type(mnemonic.title(), (RiscObfInstructionNew,), members)


